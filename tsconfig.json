{
  "compilerOptions": {
    "baseUrl": "src",
    "moduleResolution": "Node",
    "target": "es2021",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["es2021", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "jsx": "react-jsx",
    /* Bundler mode */
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "erasableSyntaxOnly": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true
  },
  "exclude": ["dist"],
  "include": ["vite.config.ts", "vite.config-dev.ts", "vite.config-test.ts", "vitest-setup-tests.ts", "src", "demos", "test", "check-version.js"]
}
